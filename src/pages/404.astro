---
import PageLayout from '../layouts/PageLayout.astro';
---
<PageLayout title="页面没有找到" description="你访问的页面不存在。">
	<div class="container missing"><span>404</span><h1>这里暂时没有实验记录。</h1><p>可能是链接已经改变，或者文章还在整理中。</p><a href="/">返回首页 →</a></div>
</PageLayout>
<style>.missing { padding: 140px 0; text-align: center; }.missing span { color: var(--accent); font-weight: 900; }.missing h1 { margin: 16px 0; font-size: clamp(36px, 6vw, 64px); }.missing p { color: var(--muted); }.missing a { font-weight: 800; text-decoration: none; }</style>
