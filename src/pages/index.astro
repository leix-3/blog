---
import { getCollection } from 'astro:content';
import ArticleCard from '../components/ArticleCard.astro';
import PageLayout from '../layouts/PageLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !import.meta.env.PROD || !data.draft))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const popularTags = [...new Set(posts.flatMap((post) => post.data.tags))]
	.map((tag) => ({ tag, count: posts.filter((post) => post.data.tags.includes(tag)).length }))
	.sort((a, b) => b.count - a.count || a.tag.localeCompare(b.tag, 'zh-CN'))
	.slice(0, 8);
const websiteJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: SITE_TITLE,
	description: SITE_DESCRIPTION,
	url: Astro.site,
};
---

<PageLayout title={SITE_TITLE} description={SITE_DESCRIPTION} jsonLd={websiteJsonLd}>
	<section class="latest container">
		<div class="section-heading">
			<div><p class="eyebrow">LATEST NOTES</p><h2>最新文章</h2></div>
			<a class="all-link" href="/blog/">查看全部文章 →</a>
		</div>
		<div class="article-tools" data-article-tools>
			<label class="search-box">
				<span class="sr-only">搜索文章</span>
				<span aria-hidden="true">⌕</span>
				<input type="search" placeholder="搜索标题、分类或标签" autocomplete="off" data-article-search />
			</label>
			<div class="tag-filters" aria-label="按标签筛选文章">
				<button class="active" type="button" data-tag-filter="" aria-pressed="true">全部</button>
				{popularTags.map(({ tag }) => <button type="button" data-tag-filter={tag} aria-pressed="false">#{tag}</button>)}
			</div>
		</div>
		<div class="post-grid">
			{posts.map((post) => (
				<div
					class="post-item"
					data-post-item
					data-search={`${post.data.title} ${post.data.description} ${post.data.category} ${post.data.tags.join(' ')}`.toLocaleLowerCase('zh-CN')}
					data-tags={post.data.tags.join('|')}
				>
					<ArticleCard post={post} compact />
				</div>
			))}
		</div>
		<p class="no-results" data-no-results hidden>没有找到匹配的文章，换个关键词试试。</p>
	</section>

	<section class="about-strip">
		<div class="container about-grid">
			<p class="eyebrow">ABOUT A LEI</p>
			<h2>少一点概念，<br />多一点亲手实践。</h2>
			<div>
				<p>我是阿雷，一名喜欢研究 AI、NAS 和内容创作流程的实践者。我希望把折腾过程中真正有用的经验，整理成普通人也能照着完成的方法。</p>
				<a href="/about/">了解我为什么做这个网站 →</a>
			</div>
		</div>
	</section>
</PageLayout>

<script>
	const tools = document.querySelector<HTMLElement>('[data-article-tools]');
	const search = document.querySelector<HTMLInputElement>('[data-article-search]');
	const items = [...document.querySelectorAll<HTMLElement>('[data-post-item]')];
	const buttons = [...document.querySelectorAll<HTMLButtonElement>('[data-tag-filter]')];
	const noResults = document.querySelector<HTMLElement>('[data-no-results]');
	let activeTag = '';

	function updateArticles() {
		const query = search?.value.trim().toLocaleLowerCase('zh-CN') ?? '';
		let visibleCount = 0;

		items.forEach((item) => {
			const matchesQuery = !query || item.dataset.search?.includes(query);
			const matchesTag = !activeTag || item.dataset.tags?.split('|').includes(activeTag);
			const show = Boolean(matchesQuery && matchesTag);
			item.hidden = !show;
			if (show) visibleCount += 1;
		});

		if (noResults) noResults.hidden = visibleCount > 0;
	}

	search?.addEventListener('input', updateArticles);
	buttons.forEach((button) => {
		button.addEventListener('click', () => {
			activeTag = button.dataset.tagFilter ?? '';
			buttons.forEach((item) => {
				const active = item === button;
				item.classList.toggle('active', active);
				item.setAttribute('aria-pressed', String(active));
			});
			updateArticles();
		});
	});

	tools?.classList.add('ready');
</script>

<style>
	.latest { padding-top: 58px; }
	.latest .post-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 38px 22px; }
	.post-item[hidden], .no-results[hidden] { display: none; }
	.article-tools { display: grid; grid-template-columns: minmax(240px, .75fr) minmax(0, 1.8fr); gap: 18px; align-items: center; margin: -4px 0 30px; padding-bottom: 22px; border-bottom: 1px solid var(--line); }
	.search-box { display: flex; align-items: center; gap: 9px; min-height: 42px; padding: 0 14px; border: 1px solid var(--line); border-radius: 999px; background: var(--surface); color: var(--muted); }
	.search-box:focus-within { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-soft); }
	.search-box input { min-width: 0; width: 100%; border: 0; outline: 0; background: transparent; color: var(--ink); font-size: 14px; }
	.search-box input::placeholder { color: var(--muted); }
	.tag-filters { display: flex; overflow-x: auto; gap: 8px; padding: 2px 0; scrollbar-width: none; }
	.tag-filters::-webkit-scrollbar { display: none; }
	.tag-filters button { flex: 0 0 auto; padding: 7px 11px; border: 1px solid var(--line); border-radius: 999px; background: transparent; color: var(--muted); font-size: 12px; cursor: pointer; }
	.tag-filters button:hover, .tag-filters button.active { border-color: var(--accent); background: var(--accent-soft); color: var(--accent); }
	.no-results { margin: 44px 0 0; padding: 36px; border: 1px dashed var(--line); border-radius: 16px; color: var(--muted); text-align: center; }
	.all-link { color: var(--accent); font-size: 14px; font-weight: 750; text-decoration: none; }
	.about-strip { margin-top: 110px; padding: 90px 0; background: var(--deep-bg); color: var(--deep-ink); }
	.about-grid { display: grid; grid-template-columns: .5fr 1fr 1fr; gap: 60px; align-items: start; }
	.about-grid h2 { margin: 0; font-size: clamp(32px, 5vw, 54px); letter-spacing: -.04em; line-height: 1.15; }
	.about-grid div p { margin: 0 0 24px; color: var(--deep-muted); }
	.about-grid a { color: var(--deep-link); font-weight: 750; text-decoration: none; }
	@media (max-width: 900px) { .article-tools { grid-template-columns: 1fr; } .latest .post-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } .about-grid { grid-template-columns: 1fr; gap: 28px; } }
	@media (max-width: 600px) { .latest { padding-top: 42px; } .article-tools { margin-bottom: 24px; } .latest .post-grid { grid-template-columns: 1fr; } }
</style>
