---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = (await getCollection('blog', ({ data }) => !import.meta.env.PROD || !data.draft))
		.sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());
	return posts.map((post, index) => {
		const related = posts
			.filter((item) => item.id !== post.id && !item.data.draft && (item.data.category === post.data.category || item.data.tags.some((tag) => post.data.tags.includes(tag))))
			.slice(0, 2);
		return {
			params: { slug: post.id },
			props: { post, previous: posts[index - 1], next: posts[index + 1], related },
		};
	});
}
type Props = { post: CollectionEntry<'blog'>; previous?: CollectionEntry<'blog'>; next?: CollectionEntry<'blog'>; related: CollectionEntry<'blog'>[] };

const { post, previous, next, related } = Astro.props;
const { Content, headings } = await render(post);
---

<BlogPost post={post} headings={headings} previous={previous} next={next} related={related}>
	<Content />
</BlogPost>
