---
import { getCollection } from 'astro:content';
import ArticleCard from '../../components/ArticleCard.astro';
import PageLayout from '../../layouts/PageLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !import.meta.env.PROD || !data.draft))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<PageLayout title="全部文章" description="阿雷实验室的全部实践文章。">
	<div class="container">
		<header class="page-hero"><p class="eyebrow">ALL NOTES</p><h1>全部文章</h1><p>关于 AI、NAS、效率软件、内容创作和家庭教育的实践记录。</p></header>
		<div class="post-grid">{posts.map((post) => <ArticleCard post={post} />)}</div>
	</div>
</PageLayout>
