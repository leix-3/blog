---
import { NAV_LINKS, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a class="brand" href="/" aria-label={`${SITE_TITLE}首页`}>
			<span class="brand-mark">A</span>
			<span>{SITE_TITLE}</span>
		</a>
		<div class="internal-links">
			{NAV_LINKS.map((link) => <HeaderLink href={link.href}>{link.label}</HeaderLink>)}
		</div>
		<div class="nav-actions">
			<button class="theme-toggle" type="button" data-theme-toggle aria-label="切换网站皮肤" aria-pressed="false">
				<span class="theme-swatch" aria-hidden="true"></span>
				<span data-theme-label>墨夜</span>
			</button>
			<a class="subscribe" href="/rss.xml">RSS 订阅</a>
		</div>
	</nav>
</header>
<script>
	const syncThemeControls = () => {
		const isEditorial = document.documentElement.dataset.theme === 'editorial';
		document.querySelectorAll<HTMLElement>('[data-theme-toggle]').forEach((button) => {
			button.setAttribute('aria-pressed', String(isEditorial));
			const label = button.querySelector<HTMLElement>('[data-theme-label]');
			if (label) label.textContent = isEditorial ? '自然' : '墨夜';
		});
	};

	document.querySelectorAll<HTMLElement>('[data-theme-toggle]').forEach((button) => {
		button.addEventListener('click', () => {
			const nextTheme = document.documentElement.dataset.theme === 'editorial' ? 'natural' : 'editorial';
			document.documentElement.dataset.theme = nextTheme;
			try { localStorage.setItem('alei-theme', nextTheme); } catch {}
			syncThemeControls();
		});
	});
	syncThemeControls();
</script>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 20;
		border-bottom: 1px solid var(--line);
		background: var(--header-bg);
		backdrop-filter: blur(18px);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: min(1180px, calc(100% - 40px));
		height: 72px;
		margin: 0 auto;
	}
	.brand {
		display: flex;
		gap: 10px;
		align-items: center;
		color: var(--ink);
		font-weight: 800;
		text-decoration: none;
	}
	.brand-mark {
		display: grid;
		place-items: center;
		width: 34px;
		height: 34px;
		border-radius: 10px;
		background: var(--accent);
		color: white;
		font-size: 16px;
	}
	.internal-links {
		display: flex;
		gap: 26px;
	}
	.nav-actions { display: flex; align-items: center; gap: 9px; }
	.theme-toggle {
		display: flex;
		gap: 8px;
		align-items: center;
		padding: 9px 12px;
		border: 1px solid var(--line);
		border-radius: 999px;
		background: var(--panel-bg);
		color: var(--muted);
		font-size: 13px;
		font-weight: 750;
		cursor: pointer;
	}
	.theme-swatch { width: 12px; height: 12px; border-radius: 50%; background: linear-gradient(135deg, #111512 50%, #c9a76a 50%); box-shadow: 0 0 0 2px var(--surface); }
	.theme-toggle[aria-pressed="true"] .theme-swatch { background: linear-gradient(135deg, #f7f8f5 50%, #1f7550 50%); }
	.subscribe {
		padding: 9px 14px;
		border: 1px solid var(--ink);
		border-radius: 999px;
		color: var(--ink);
		font-size: 14px;
		font-weight: 700;
		text-decoration: none;
	}
	@media (max-width: 820px) {
		nav { width: min(100% - 28px, 1180px); height: 64px; }
		.internal-links {
			display: none;
		}
		.subscribe { display: none; }
	}
</style>
