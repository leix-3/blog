---
import { NAV_LINKS, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a class="brand" href="/" aria-label={`${SITE_TITLE}首页`}>
			<span class="brand-mark">A</span>
			<span>{SITE_TITLE}</span>
		</a>
		<div class="internal-links">
			{NAV_LINKS.map((link) => <HeaderLink href={link.href}>{link.label}</HeaderLink>)}
		</div>
		<a class="subscribe" href="/rss.xml">RSS 订阅</a>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 20;
		border-bottom: 1px solid var(--line);
		background: rgba(247, 248, 245, 0.92);
		backdrop-filter: blur(18px);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: min(1180px, calc(100% - 40px));
		height: 72px;
		margin: 0 auto;
	}
	.brand {
		display: flex;
		gap: 10px;
		align-items: center;
		color: var(--ink);
		font-weight: 800;
		text-decoration: none;
	}
	.brand-mark {
		display: grid;
		place-items: center;
		width: 34px;
		height: 34px;
		border-radius: 10px;
		background: var(--accent);
		color: white;
		font-size: 16px;
	}
	.internal-links {
		display: flex;
		gap: 26px;
	}
	.subscribe {
		padding: 9px 14px;
		border: 1px solid var(--ink);
		border-radius: 999px;
		color: var(--ink);
		font-size: 14px;
		font-weight: 700;
		text-decoration: none;
	}
	@media (max-width: 820px) {
		nav { width: min(100% - 28px, 1180px); height: 64px; }
		.internal-links {
			display: none;
		}
	}
</style>
