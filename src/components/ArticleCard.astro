---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';

interface Props {
	post: CollectionEntry<'blog'>;
	featured?: boolean;
}

const { post, featured = false } = Astro.props;

function categorySlug(category: string) {
	return {
		'AI 工具': 'ai',
		'NAS 数码': 'nas',
		'效率软件': 'software',
		'内容创作': 'content',
		'家庭教育': 'education',
	}[category] ?? 'ai';
}
---

<article class:list={['article-card', { featured }]}>
	<a class="cover" href={`/blog/${post.id}/`} aria-label={`阅读《${post.data.title}》`}>
		{post.data.heroImage ? (
			<Image src={post.data.heroImage} width={featured ? 900 : 560} height={featured ? 540 : 340} alt={post.data.title} />
		) : (
			<div class="cover-placeholder">{post.data.category}</div>
		)}
	</a>
	<div class="content">
		<div class="meta">
			<a href={`/category/${categorySlug(post.data.category)}/`}>{post.data.category}</a>
			<span>·</span>
			<FormattedDate date={post.data.pubDate} />
		</div>
		<h3><a href={`/blog/${post.id}/`}>{post.data.title}</a></h3>
		<p>{post.data.description}</p>
		<div class="tags">
			{post.data.tags.slice(0, 3).map((tag) => <a href={`/tag/${encodeURIComponent(tag)}/`}>#{tag}</a>)}
		</div>
	</div>
</article>

<style>
	.article-card { min-width: 0; }
	.cover { display: block; overflow: hidden; aspect-ratio: 1.65; border-radius: 18px; background: var(--surface); }
	.cover :global(img) { width: 100%; height: 100%; object-fit: cover; transition: transform .35s ease; }
	.cover:hover :global(img) { transform: scale(1.025); }
	.cover-placeholder { display: grid; place-items: center; height: 100%; color: var(--accent); font-weight: 800; background: linear-gradient(135deg, var(--accent-soft), var(--surface)); }
	.content { padding: 18px 2px 0; }
	.meta { display: flex; gap: 8px; align-items: center; color: var(--muted); font-size: 13px; }
	.meta a { color: var(--accent); font-weight: 750; text-decoration: none; }
	h3 { margin: 9px 0 8px; font-size: clamp(20px, 2vw, 26px); line-height: 1.35; }
	h3 a { color: var(--ink); text-decoration: none; }
	p { margin: 0; color: var(--muted); font-size: 15px; line-height: 1.75; }
	.tags { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 14px; }
	.tags a { color: var(--muted); font-size: 12px; text-decoration: none; }
	.featured { display: grid; grid-template-columns: minmax(0, 1.25fr) minmax(280px, .75fr); gap: 38px; align-items: center; }
	.featured .content { padding: 0; }
	.featured h3 { font-size: clamp(28px, 4vw, 44px); letter-spacing: -.03em; }
	.featured p { font-size: 17px; }
	@media (max-width: 760px) {
		.featured { display: block; }
		.featured .content { padding-top: 20px; }
	}
</style>
