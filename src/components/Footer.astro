---
import { CATEGORIES, SITE_DESCRIPTION, SITE_TITLE } from '../consts';
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div>
			<a class="footer-brand" href="/">{SITE_TITLE}</a>
			<p>{SITE_DESCRIPTION}</p>
		</div>
		<div class="footer-links">
			{CATEGORIES.map((category) => <a href={`/category/${category.slug}/`}>{category.name}</a>)}
			<a href="/about/">关于我</a>
		</div>
	</div>
	<div class="copyright">© {today.getFullYear()} {SITE_TITLE} · 由内容与好奇心驱动</div>
</footer>
<style>
	footer {
		margin-top: 80px;
		padding: 56px 20px 32px;
		border-top: 1px solid var(--line);
		background: var(--footer-bg);
		color: var(--muted);
	}
	.footer-inner {
		display: flex;
		justify-content: space-between;
		width: min(1100px, 100%);
		margin: 0 auto 48px;
	}
	.footer-brand { color: var(--ink); font-size: 22px; font-weight: 800; text-decoration: none; }
	.footer-inner p { max-width: 430px; margin: 10px 0 0; font-size: 15px; }
	.footer-links { display: grid; grid-template-columns: repeat(2, auto); gap: 10px 34px; }
	.footer-links a { color: var(--muted); font-size: 14px; text-decoration: none; }
	.copyright {
		width: min(1100px, 100%);
		margin: 0 auto;
		padding-top: 24px;
		border-top: 1px solid rgba(30, 44, 36, 0.1);
		font-size: 13px;
	}
	@media (max-width: 720px) {
		.footer-inner { display: block; }
		.footer-links { margin-top: 30px; }
	}
</style>
